class Solution {
    public boolean isSubsequence(String s, String t) {
       StringBuilder sb=new StringBuilder();
       int k=0;
       for(int i=0;i<t.length() && k<s.length() ;i++){
        if(s.charAt(k)==t.charAt(i)){
            sb.append(s.charAt(k));
            k++;
        }
       } return sb.toString().equals(s);
    }
}
